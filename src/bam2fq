#!/usr/bin/env python3
# bam2fq.py
# Generate samtools fastq commands for BAM to FASTQ conversion

import argparse
import glob
import os
import shlex
import sys


############
# argparse #
############

parser = argparse.ArgumentParser(description="BAM to FASTQ Command Generator")
parser.add_argument("-i", "--input", required=True,
	help="Path to the directory containing BAM files")
parser.add_argument("-o", "--output", required=True,
	help="Path to the output directory for FASTQ files")
parser.add_argument("-t", "--threads", type=int, default=4,
	help="Total threads per samtools fastq process [%(default)i]")
parser.add_argument("--cmd-file", default="./bam2fq_cmd.txt",
	help="Path for the generated command file [%(default)s]")
args = parser.parse_args()


########
# main #
########

input_dir = os.path.abspath(os.path.expanduser(args.input))
output_dir = os.path.abspath(os.path.expanduser(args.output))
cmd_file = os.path.abspath(os.path.expanduser(args.cmd_file))
at_threads = max(0, args.threads - 1)

os.makedirs(output_dir, exist_ok=True)

if not os.path.exists(input_dir):
	sys.exit(f"[bam2fq] Error: Directory {args.input} does not exist")

bam_files = sorted([fn for fn in glob.glob(os.path.join(input_dir, "*.bam")) if os.path.isfile(fn)])
num_files = len(bam_files)

print(f"[bam2fq] Checking directory: {input_dir}", file=sys.stderr)
print(f"[bam2fq] Found {num_files} BAM files", file=sys.stderr)

if num_files == 0:
	sys.exit(f"[bam2fq] Error: {args.input} has 0 BAM files")

commands = []
for bam in bam_files:
	bname = os.path.splitext(os.path.basename(bam))[0]
	out_fq = os.path.join(output_dir, f"{bname}.fastq")
	cmd = f"{shlex.join(['samtools', 'fastq', '-@', str(at_threads), bam])} > {shlex.quote(out_fq)}"
	commands.append(cmd)

with open(cmd_file, "w") as f:
	for cmd in commands:
		f.write(cmd + "\n")

print(f"[bam2fq] Wrote {len(commands)} commands to {cmd_file}", file=sys.stderr)
